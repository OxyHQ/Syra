{
  "name": "@syra.fm/live",
  "version": "0.1.0",
  "description": "Syra live rooms engine (DI-based; audio rooms over LiveKit)",
  "source": "src/index.ts",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/commonjs/index.d.ts",
  "react-native": "src/index.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "browser": {
        "types": "./lib/typescript/module/index.d.ts",
        "import": "./lib/module/index.js",
        "require": "./lib/commonjs/index.js"
      },
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    },
    "./src/assets/*": "./src/assets/*",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bob build",
    "prepare": "bob build || true",
    "clean": "rm -rf lib"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "exclude": "{**/{__tests__,__mocks__}/**,**/*.{test,spec}.{ts,tsx},**/*.mp3}",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "peerDependencies": {
    "react": "^19.2.3",
    "react-native": "^0.85.3",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "^5.7.0",
    "@oxyhq/services": "^13.1.7",
    "@oxyhq/core": "^5.2.1",
    "livekit-client": "^2.20.0",
    "@livekit/react-native": "^2.11.1",
    "expo-audio": "~56.0.12",
    "expo-image-picker": "~56.0.18",
    "socket.io-client": "^4.8.1",
    "@expo/vector-icons": "^15.0.2",
    "react-native-svg": "15.15.4",
    "sonner-native": "^0.21.1",
    "expo-blur": "~56.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "@types/react": "~19.2.14",
    "react-native-builder-bob": "^0.40.16",
    "nativewind": "5.0.0-preview.3"
  },
  "dependencies": {}
}
