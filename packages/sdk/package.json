{
  "name": "@syra.fm/sdk",
  "version": "0.6.0",
  "description": "Syra SDK — headless, isomorphic catalog client (Node/React-free, public reads + 30s previews) that also ships the Syra live-rooms engine (audio rooms over LiveKit) on React Native and web.",
  "source": "src/index.ts",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/commonjs/index.d.ts",
  "react-native": "src/index.native.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "react-native": "./src/index.native.ts",
      "browser": {
        "types": "./lib/typescript/module/index.native.d.ts",
        "import": "./lib/module/index.native.js",
        "require": "./lib/commonjs/index.native.js"
      },
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      },
      "default": "./lib/module/index.js"
    },
    "./src/live/assets/*": "./src/live/assets/*",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib"
  ],
  "keywords": [
    "syra",
    "sdk",
    "music",
    "api-client",
    "preview",
    "live-rooms"
  ],
  "author": "Syra Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "bob build",
    "clean": "rm -rf lib",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "bun test src",
    "prepublishOnly": "bun run build"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "exclude": "{**/{__tests__,__mocks__}/**,**/*.{test,spec}.{ts,tsx},**/*.mp3}",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "react": "^19.2.3",
    "react-native": "^0.85.3",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "^5.7.0",
    "@oxyhq/services": "^15.0.0",
    "livekit-client": "^2.20.0",
    "@livekit/react-native": "^2.11.1",
    "expo-audio": "~56.0.12",
    "expo-image-picker": "~56.0.18",
    "socket.io-client": "^4.8.1",
    "@expo/vector-icons": "^15.0.2",
    "react-native-svg": "15.15.4",
    "expo-blur": "~56.0.3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-reanimated": {
      "optional": true
    },
    "react-native-safe-area-context": {
      "optional": true
    },
    "@oxyhq/services": {
      "optional": true
    },
    "livekit-client": {
      "optional": true
    },
    "@livekit/react-native": {
      "optional": true
    },
    "expo-audio": {
      "optional": true
    },
    "expo-image-picker": {
      "optional": true
    },
    "socket.io-client": {
      "optional": true
    },
    "@expo/vector-icons": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    },
    "expo-blur": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "~19.2.14",
    "react-native-builder-bob": "^0.40.16",
    "nativewind": "5.0.0-preview.3",
    "typescript": "~5.9.3",
    "react": "^19.2.3",
    "react-native": "^0.85.3",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "^5.7.0",
    "@oxyhq/services": "^15.0.0",
    "livekit-client": "^2.20.0",
    "@livekit/react-native": "^2.11.1",
    "expo-audio": "~56.0.12",
    "expo-image-picker": "~56.0.18",
    "socket.io-client": "^4.8.1",
    "@expo/vector-icons": "^15.0.2",
    "react-native-svg": "15.15.4",
    "expo-blur": "~56.0.3"
  }
}
