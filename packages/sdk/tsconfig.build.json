{
  "compilerOptions": {
    "rootDir": "src",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "types": ["react", "node", "nativewind/types"]
  },
  "include": ["src"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "lib", "node_modules"]
}
