{
  "name": "@syra/backend",
  "version": "1.0.0",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "server.ts",
  "scripts": {
    "start": "ts-node --transpile-only server.ts",
    "dev": "nodemon --watch \"**/*.ts\" --exec ts-node --transpile-only server.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "migrate": "ts-node --transpile-only scripts/migrate.ts",
    "migrate:dev": "NODE_ENV=development ts-node --transpile-only scripts/migrate.ts",
    "seed:music": "ts-node --transpile-only src/scripts/seedMusicData.ts",
    "migrate:catalog-entities": "ts-node --transpile-only src/scripts/migrateArtistsToCatalogEntities.ts",
    "reseed:persons": "ts-node --transpile-only src/scripts/reseedPersons.ts",
    "test": "rm -rf dist && bun test src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@aws-sdk/s3-request-presigner": "^3.1087.0",
    "@socket.io/redis-adapter": "^8.2.0",
    "@syra.fm/sdk": "workspace:*",
    "@syra/shared-types": "workspace:*",
    "@types/compression": "^1.8.1",
    "@types/multer": "^2.2.0",
    "@types/sharp": "^0.32.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.3.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.0.1",
    "express-slow-down": "^3.1.0",
    "express-validator": "^7.0.1",
    "fast-xml-parser": "^5.10.0",
    "firebase-admin": "^14.1.0",
    "i18n": "^0.15.1",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "livekit-server-sdk": "^2.17.0",
    "mongoose": "^9.7.4",
    "multer": "^2.1.1",
    "node-telegram-bot-api": "^1.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode-terminal": "^0.12.0",
    "redis": "^6.1.0",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.1",
    "url-metadata": "^5.7.4",
    "validator": "^13.15.22",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  }
}
