# =============================================================================
# @syra/backend — runtime environment variables
# =============================================================================
# Copy to `.env` for local development. In production (AWS / containers) these
# are injected by the platform; NEVER commit a real `.env`.
#
# Lines marked  [SECRET]  must be provided via a secret manager (AWS Secrets
# Manager / SSM Parameter Store / ECS secrets), not baked into the image.
# Lines marked  [public]  are safe plain config values.
# Lines marked  [optional]  have working defaults and may be omitted.
# -----------------------------------------------------------------------------

# --- Core server -------------------------------------------------------------
# [public]   Node runtime mode. Use "production" in deployed environments.
NODE_ENV=production
# [optional] HTTP port the server listens on (binds 0.0.0.0). Default: 3000.
PORT=3000

# --- Database (MongoDB) ------------------------------------------------------
# [SECRET]   MongoDB connection string (mongodb:// or mongodb+srv://).
#            Required; the server boots without it but all DB ops fail.
MONGODB_URI=
# [optional] Connection pool tuning (defaults: max=100, min=10).
# MONGODB_MAX_POOL_SIZE=100
# MONGODB_MIN_POOL_SIZE=10
# [optional] Read preference (default: primary). e.g. secondaryPreferred
# MONGODB_READ_PREFERENCE=primary

# --- Cache / pub-sub (Redis) -------------------------------------------------
# [SECRET]   Redis connection URL (redis:// or rediss://). Used for rate
#            limiting and Socket.IO horizontal scaling. App degrades to
#            single-instance mode if unset/unreachable.
REDIS_URL=
# [optional] Alternative to REDIS_URL — discrete host/port/password/db.
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=            # [SECRET] if Redis auth is enabled
# REDIS_DB=0

# --- Authentication ----------------------------------------------------------
# [SECRET]   JWT signing/verification secret. Authentication is delegated to the
#            Oxy platform via @oxyhq/core; provide this so the Oxy SDK and any
#            token verification share the same secret as the Oxy API.
JWT_SECRET=

# --- Oxy platform integration ------------------------------------------------
# [public]   Base URL of the Oxy API (auth / user data). Default: https://api.oxy.so
OXY_API_URL=https://api.oxy.so
# [public]   Public frontend origin (CORS + Socket.IO allow-list).
#            Default: https://syra.oxy.so
FRONTEND_URL=https://syra.oxy.so

# --- Object storage (S3-compatible: AWS S3 or DigitalOcean Spaces) -----------
# Credentials: provide EITHER the SPACES_* pair (DigitalOcean Spaces) OR the
# AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY pair (AWS S3). SPACES_* takes priority.
#
# [SECRET]   DigitalOcean Spaces access key.
SPACES_KEY=
# [SECRET]   DigitalOcean Spaces secret key.
SPACES_SECRET=
# [SECRET]   AWS S3 access key id (use instead of SPACES_KEY for AWS S3).
# AWS_ACCESS_KEY_ID=
# [SECRET]   AWS S3 secret access key (use instead of SPACES_SECRET for AWS S3).
# AWS_SECRET_ACCESS_KEY=
#
# [public]   Storage region. AWS e.g. us-east-1; Spaces e.g. fra1 / ams3.
AWS_REGION=us-east-1
# [public]   Custom S3 endpoint. REQUIRED for DigitalOcean Spaces
#            (https://<region>.digitaloceanspaces.com). Leave UNSET for AWS S3.
# AWS_ENDPOINT_URL=https://fra1.digitaloceanspaces.com
# [public]   Bucket name. (AWS_S3_BUCKET_NAME is also accepted as an alias.)
AWS_S3_BUCKET=syra-audio
# [optional] Key prefix for stored audio objects. Default: audio
S3_AUDIO_PREFIX=audio

# --- Firebase (push notifications via firebase-admin) ------------------------
# [public]   Firebase project id.
FIREBASE_PROJECT_ID=
# [SECRET]   Firebase service-account JSON, base64-encoded.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# --- Optional third-party integrations ---------------------------------------
# [SECRET][optional] OpenAI API key (AI features). Unused unless AI paths invoked.
# OPENAI_API_KEY=
# [SECRET][optional] Telegram bot token (operational notifications).
# TELEGRAM_BOT_TOKEN=
# [SECRET][optional] Klipy API key (GIF search in gifService).
# KLIPY_APP_KEY=

# --- Link-preview image tuning (optional) ------------------------------------
# LINK_PREVIEW_MAX_WIDTH=
# LINK_PREVIEW_MAX_HEIGHT=
# LINK_PREVIEW_MAX_FILE_SIZE=
# LINK_PREVIEW_JPEG_QUALITY=
# LINK_PREVIEW_PNG_QUALITY=
# LINK_PREVIEW_WEBP_QUALITY=
