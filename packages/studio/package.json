{
  "name": "@syra/studio",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "description": "Syra Studio — manage podcast shows, upload episodes, generated RSS feed",
  "scripts": {
    "start": "expo start --reset-cache --clear",
    "dev": "expo start --reset-cache --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export --platform web --output-dir dist && bun ./scripts/remove-css-preloads.mjs",
    "build-web": "expo export --platform web --output-dir dist && bun ./scripts/remove-css-preloads.mjs",
    "build-web:prod": "expo export --platform web --output-dir dist && bun ./scripts/remove-css-preloads.mjs",
    "test": "jest --watchAll=false",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "clean": "rm -rf dist .expo"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-syntax-import-meta": "^7.10.4",
    "@babel/plugin-transform-dynamic-import": "^7.27.1",
