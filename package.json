{
  "name": "syra",
  "version": "2.0.0",
  "description": "Syra Monorepo - Music Streaming App Frontend and Backend",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:frontend": "bun run --filter '@syra/frontend' dev",
    "dev:studio": "bun run --filter '@syra/studio' dev",
    "dev:backend": "bun run --filter '@syra/backend' dev",
    "build": "bun run --filter '*' build",
    "build:shared-types": "bun run --filter '@syra/shared-types' build",
    "build:sdk": "bun run --filter '@syra.fm/sdk' build",
    "build:frontend": "bun run --filter '@syra/frontend' build",
    "build:studio": "bun run --filter '@syra/studio' build",
    "build:backend": "bun run --filter '@syra/backend' build",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "clean": "bun run --filter '*' clean && rm -rf node_modules",
    "install:all": "bun install",
    "start:frontend": "bun run --filter '@syra/frontend' start",
    "start:studio": "bun run --filter '@syra/studio' start",
    "start:backend": "bun run --filter '@syra/backend' start",
    "postinstall": "bun run --filter '@syra/shared-types' build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@oxyhq/bloom": "^0.39.0",
    "@oxyhq/core": "^12.4.1",
    "@oxyhq/services": "^22.1.0",
    "@tanstack/query-async-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-persist-client": "^5.101.2"
  },
  "overrides": {
    "@oxyhq/core": "^12.4.1",
    "mongodb-connection-string-url": "7.0.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-css": "3.0.7",
    "nativewind": "5.0.0-preview.3",
    "tailwindcss": "4.2.2",
    "lightningcss": "1.30.1",
    "lightningcss-linux-x64-gnu": "1.30.1"
  }
}
