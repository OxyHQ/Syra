{
  "name": "syra",
  "version": "2.0.0",
  "description": "Syra Monorepo - Music Streaming App Frontend and Backend",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:frontend": "bun run --filter '@syra/frontend' dev",
    "dev:backend": "bun run --filter '@syra/backend' dev",
    "build": "bun run --filter '*' build",
    "build:shared-types": "bun run --filter '@syra/shared-types' build",
    "build:frontend": "bun run --filter '@syra/frontend' build",
    "build:backend": "bun run --filter '@syra/backend' build",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "clean": "bun run --filter '*' clean && rm -rf node_modules",
    "install:all": "bun install",
    "start:frontend": "bun run --filter '@syra/frontend' start",
    "start:backend": "bun run --filter '@syra/backend' start",
    "postinstall": "bun run --filter '@syra/shared-types' build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@oxyhq/services": "^8.0.0",
    "@oxyhq/bloom": "0.6.11",
    "@oxyhq/core": "2.0.0",
    "@tanstack/react-query": "^5.100.0",
    "@tanstack/react-query-persist-client": "^5.100.0",
    "@tanstack/query-async-storage-persister": "^5.100.0",
    "@react-native/js-polyfills": "^0.81.1",
    "react-native-css-interop": "^0.2.0",
    "react-native-worklets": "0.8.3",
    "react-native-worklets-core": "^1.6.2"
  }
}
